# Supabase configuration
# Copy this file to `.env` for local development and set the same variables in your
# Vercel project settings (Settings -> Environment Variables) for deployment.

# Client-side (exposed to the browser, injected at build time by Vite).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-side (available to SSR / server functions only). Mirror the values above.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Server-side admin key. NEVER expose this to the client. Bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=

# Server-side safety limits to prevent unbounded league creation/storage growth.
# MAX_LEAGUES_TOTAL: hard cap on total leagues in the database.
# MAX_LEAGUES_PER_HOUR: cap on new leagues created in the last rolling hour.
# Optional; defaults are used when unset.
MAX_LEAGUES_TOTAL=10000
MAX_LEAGUES_PER_HOUR=120
