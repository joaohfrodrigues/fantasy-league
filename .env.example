# Supabase configuration
# Copy this file to `.env` for local development and set the same variables in your
# Vercel project settings (Settings -> Environment Variables) for deployment.

# Client-side (exposed to the browser, injected at build time by Vite).
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Canonical site origin (no trailing slash), e.g. https://your-domain.com. Used to
# build absolute Open Graph / Twitter image URLs for link previews. Optional but
# recommended — without it, preview images may not render in some chat apps.
VITE_SITE_URL=

# Server-side (available to SSR / server functions only). Mirror the values above.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Server-side admin key. NEVER expose this to the client. Bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=

# Server-side abuse backstop. There is no fixed total-league ceiling (removed so
# the product can grow without bound). MAX_LEAGUES_PER_HOUR is a generous global
# hourly cap (DB-counted) guarding against runaway storage growth across instances;
# per-IP burst limiting is handled in-process. Optional; default used when unset.
MAX_LEAGUES_PER_HOUR=1000
